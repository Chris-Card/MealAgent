# =============================================================================
# MealAgent - Production environment template
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Email (Gmail SMTP) - Required ---
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
TARGET_EMAIL=

# --- Servings ---
ADULT_SERVINGS=2
CHILD_SERVINGS=2
LEFTOVERS_FACTOR=1.3

# --- Dietary preferences ---
MEAL_TYPES=high_protein,vegetarian,kid_friendly,balanced
ALLERGIES_AVOID=

# --- Claude / Anthropic - Required ---
ANTHROPIC_API_KEY=
MODEL_NAME=claude-3-5-haiku-latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384

# --- Schedule & behavior ---
RUN_DAY=MONDAY
TIMEZONE=America/New_York
INCLUDE_HTML_EMAIL=true
